# ─── PocketBase (Self-Hosted) ─────────────────────────────────────────────────
# Your Cloudflare Tunnel URL, e.g. https://api.deine-domain.de
EXPO_PUBLIC_PB_URL=https://api.deine-domain.de

# ─── Maps APIs ────────────────────────────────────────────────────────────────
# Google Maps SDK (for react-native-maps display, Routes API, Places API)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Mapbox (for speed limit data via Map Matching API)
EXPO_PUBLIC_MAPBOX_TOKEN=

# HERE Maps (speed limit fallback for rural roads)
EXPO_PUBLIC_HERE_API_KEY=

# ─── Push Notifications ───────────────────────────────────────────────────────
# Expo Push Notifications work without Firebase — uses Expo's free service.
# No extra config needed if using expo-notifications with Expo SDK.
# If you want direct FCM (optional, for background delivery reliability):
# EXPO_PUBLIC_FCM_SERVER_KEY=
